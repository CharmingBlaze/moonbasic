; moonBASIC Smoke Test
; Validates full compiler pipeline + VM execution

pRiNt("--- moonBASIC Smoke Test ---")

; 1. Arithmetic & Promotion
x = 10
y# = 3.14
z# = x + y#
pRiNt("10 + 3.14 = ", z#)

; 2. Comparison & Logic
IF z# > 13 THEN
    pRiNt("Comparison: Correct (13.14 > 13)")
ELSE
    pRiNt("Comparison: FAILED")
ENDIF

; 3. String & Core commands
name$ = "Moon"
pRiNt("Name: ", name$, " | Length: ", LEN(name$))
pRiNt("Coerced: ", STR$(x) + " is a string now")

; 4. Function Call
res = Multiply(x, 2)
pRiNt("10 * 2 = ", res)

pRiNt("--- DONE ---")

FUNCTION Multiply(a, b)
    RETURN(a * b)
ENDFUNCTION
