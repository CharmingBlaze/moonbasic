TYPE Vec3
    X#
    Y#
    Z#
ENDTYPE

TYPE Platform
    X#, Y#, Z#
    W#, H#, D#
    R, G, B
ENDTYPE

DIM pos AS Vec3(1)
pos(0).X# = 10.0
pos(0).Y# = 5.5
pos(0).Z# = -3.0
PRINT(pos(0).X#)
PRINT(pos(0).Y#)
PRINT(pos(0).Z#)

DIM plat AS Platform(2)
plat(0) = Platform(0.0, 1.5, 6.0, 4.0, 0.4, 4.0, 255, 60, 200)
plat(1) = Platform(-3.5, 2.5, 10.0, 2.5, 0.35, 2.5, 40, 255, 230)

PRINT(plat(0).X#)
PRINT(plat(0).R)
PRINT(plat(1).X#)
PRINT(plat(1).G)

FOR i = 0 TO 1
    PRINT(plat(i).W# * plat(i).H# * plat(i).D#)
NEXT

ERASE(pos)
ERASE(plat)
PRINT("TYPE test OK")
