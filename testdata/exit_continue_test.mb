FOR i = 1 TO 10
IF i = 5 THEN EXIT FOR
PRINT(i)
NEXT

FOR i = 1 TO 5
IF i = 3 THEN CONTINUE FOR
PRINT(i)
NEXT

i = 0
WHILE TRUE
i = i + 1
IF i = 3 THEN EXIT WHILE
WEND
PRINT(i)

FOR i = 1 TO 3
FOR j = 1 TO 3
IF j = 2 THEN EXIT FOR
PRINT(STR$(i) + "," + STR$(j))
NEXT
NEXT

FUNCTION EarlyExit()
EXIT FUNCTION
PRINT(99)
ENDFUNCTION
EarlyExit()
PRINT(88)
