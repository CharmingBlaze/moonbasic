PRINT(LEFT$("hello world", 5))
PRINT(RIGHT$("hello world", 5))
PRINT(MID$("hello world", 6, 5))
PRINT(MID$("hello world", 6))
PRINT(LSET$("hi", 10))
PRINT(RSET$("hi", 10))
PRINT(SPACE$(5) + "x")
PRINT(STRING$(5, "*"))
PRINT(REVERSE$("hello"))
PRINT(REPEAT$("ab", 3))
PRINT(INSTR("hello", "ll"))
PRINT(INSTR("hello", "ll", 3))
PRINT(CONTAINS("hello world", "world"))
PRINT(STARTSWITH("hello", "hel"))
PRINT(ENDSWITH("hello", "llo"))
PRINT(COUNT$("banana", "a"))
PRINT(REPLACE$("hello", "l", "r"))
PRINT(TRIM$("  hi  "))
PRINT(FORMAT$(3.14159, "%.2f"))
PRINT(FORMAT$(42, "%05d"))
PRINT(HEX$(255))
PRINT(BIN$(10))
PRINT(OCT$(8))
PRINT(ISALPHA("hello"))
PRINT(ISNUMERIC("123"))
PRINT(ISALPHANUM("abc123"))
PRINT(TYPEOF(42))
PRINT(TYPEOF(3.14))
PRINT(TYPEOF("hi"))
PRINT(ISNULL(NULL))
PRINT(CVINT(MKINT$(99)))
PRINT(ISTYPE(42, "INT"))
PRINT("x" + LEFT$("abc", 1))
IF LEFT$("abc", 1) = "a" THEN
PRINT("heap_eq")
ENDIF
arr = SPLIT$("a,b,c", ",")
PRINT(ARRAYLEN(arr))
PRINT(JOIN$(arr, "-"))
ERASE(arr)
