Window.Open(320, 240, "model complete")
Window.SetFPS(60)

mesh = MESH.MAKECUBE(2.0, 2.0, 2.0)
mdl = MODEL.MAKE(mesh)
ASSERT(MODEL.GETMATERIALCOUNT(mdl) >= 1, "material count")

MODEL.SETPOS(mdl, -3, 1, 0)
MODEL.SETDIFFUSE(mdl, 100, 180, 255)

cam = CAMERA.MAKE()
CAMERA.SETPOS(cam, 0, 3, 10)
CAMERA.SETTARGET(cam, 0, 1, 0)
CAMERA.SETFOV(cam, 60)

frames = 0
WHILE NOT (Input.KeyDown(KEY_ESCAPE) OR Window.ShouldClose())
    Render.Clear(20, 25, 35)
    CAMERA.BEGIN(cam)
    MODEL.DRAW(mdl)
    CAMERA.END()
    Render.Frame()
    frames = frames + 1
    IF frames >= 2 THEN EXIT WHILE
WEND

CAMERA.FREE(cam)
MODEL.FREE(mdl)
MESH.FREE(mesh)

Window.Close()
PRINT("model_complete_test ok")
