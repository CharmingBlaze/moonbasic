Window.Open(1280, 720, "Model Complete Test")
Window.SetFPS(60)

cam = CAMERA.CREATE()
CAMERA.SETPOS(cam, 0, 3, 10)
CAMERA.SETTARGET(cam, 0, 1, 0)
CAMERA.SETFOV(cam, 60)

sun = LIGHT.CREATE("directional")
LIGHT.SETDIR(sun, -1, -2, -1)
LIGHT.SETINTENSITY(sun, 1.2)

cubeMesh = MESH.CREATECUBE(2, 2, 2)
sphereMesh = MESH.CREATESPHERE(1, 16, 16)
planeMesh = MESH.CREATEPLANE(10, 10, 1, 1)

cube = MODEL.CREATE(cubeMesh)
sphere = MODEL.CREATE(sphereMesh)
plane = MODEL.CREATE(planeMesh)

MODEL.SETPOS(cube, -3, 1, 0)
MODEL.SETPOS(sphere, 3, 1, 0)
MODEL.SETPOS(plane, 0, 0, 0)

MODEL.SETCOLOR(cube, 100, 180, 255, 255)
MODEL.SETCOLOR(sphere, 255, 150, 80, 255)
MODEL.SETCOLOR(plane, 80, 140, 80, 255)

MODEL.SETROUGH(cube, 0.8)
MODEL.SETMETAL(sphere, 0.9)

angle = 0.0

WHILE NOT (Input.KeyDown(KEY_ESCAPE) OR Window.ShouldClose())
    dt = Time.Delta()
    angle = angle + 30 * dt

    MODEL.SETROT(cube, 0, angle, 0)
    MODEL.SETROT(sphere, angle * 0.5, 0, angle * 0.3)

    Render.Clear(20, 25, 35)
    CAMERA.BEGIN(cam)
        MODEL.DRAW(cube)
        MODEL.DRAW(sphere)
        MODEL.DRAW(plane)
        Draw3D.Grid(10, 1.0)
    CAMERA.END()

    Draw.Text("Model Complete Test", 20, 20, 18, 255,255,200,255)
    Draw.Text("Cube / Sphere / Plane", 20, 48, 14, 200,200,200,200)
    Draw.Text("FPS: " + STR(Window.GetFPS()), 20, 70, 14, 200,200,200,200)
    Render.Frame()
WEND

MODEL.FREE(cube)
MODEL.FREE(sphere)
MODEL.FREE(plane)
MESH.FREE(cubeMesh)
MESH.FREE(sphereMesh)
MESH.FREE(planeMesh)
LIGHT.FREE(sun)
CAMERA.FREE(cam)
Window.Close()
