; Compiler check: COLLISION.* vec-handle helpers (see docs/reference/COLLISION.md)

pa = VEC2.CREATE(0, 0)
sa = VEC2.CREATE(10, 10)
pb = VEC2.CREATE(5, 5)
sb = VEC2.CREATE(10, 10)
ok = COLLISION.BOXOVERLAP2D(pa, sa, pb, sb)

c1 = VEC2.CREATE(0, 0)
c2 = VEC2.CREATE(4, 0)
ok2 = COLLISION.CIRCLEOVERLAP2D(c1, 2.0, c2, 2.0)

pt = VEC2.CREATE(1, 1)
bq = VEC2.CREATE(0, 0)
bs = VEC2.CREATE(10, 10)
ok3 = COLLISION.POINTINBOX2D(pt, bq, bs)

cc = VEC2.CREATE(5, 5)
ok4 = COLLISION.CIRCLEBOX2D(cc, 1.0, bq, bs)

a1 = VEC2.CREATE(0, 0)
a2 = VEC2.CREATE(10, 0)
b1 = VEC2.CREATE(5, -5)
b2 = VEC2.CREATE(5, 5)
ok5 = COLLISION.LINESEGINTERSECT2D(a1, a2, b1, b2)

ok6 = COLLISION.POINTONSEG2D(pt, a1, a2, 0.1)

p3 = VEC3.CREATE(0, 0, 0)
r1 = 2.0
p4 = VEC3.CREATE(3, 0, 0)
ok7 = COLLISION.SPHEREOVERLAP3D(p3, r1, p4, 2.0)

minA = VEC3.CREATE(0, 0, 0)
maxA = VEC3.CREATE(1, 1, 1)
minB = VEC3.CREATE(0.5, 0, 0)
maxB = VEC3.CREATE(2, 1, 1)
ok8 = COLLISION.AABBOVERLAP3D(minA, maxA, minB, maxB)

sC = VEC3.CREATE(0, 0, 0)
bMin = VEC3.CREATE(-1, -1, -1)
bSz = VEC3.CREATE(2, 2, 2)
ok9 = COLLISION.SPHEREBOX3D(sC, 0.5, bMin, bSz)

ok10 = COLLISION.POINTINAABB3D(p3, bMin, bSz)

VEC2.FREE(pa)
VEC2.FREE(sa)
VEC2.FREE(pb)
VEC2.FREE(sb)
VEC2.FREE(c1)
VEC2.FREE(c2)
VEC2.FREE(pt)
VEC2.FREE(bq)
VEC2.FREE(bs)
VEC2.FREE(cc)
VEC2.FREE(a1)
VEC2.FREE(a2)
VEC2.FREE(b1)
VEC2.FREE(b2)
VEC3.FREE(p3)
VEC3.FREE(p4)
VEC3.FREE(minA)
VEC3.FREE(maxA)
VEC3.FREE(minB)
VEC3.FREE(maxB)
VEC3.FREE(sC)
VEC3.FREE(bMin)
VEC3.FREE(bSz)
