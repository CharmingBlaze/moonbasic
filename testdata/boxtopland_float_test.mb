landY = BOXTOPLAND(0, 2, 0, -3, 0.5, 0, 1.5, 0, 4, 0.4, 4)
PRINT(landY > 0.0)
PRINT(FORMAT(landY, "%.2f"))
landY = BOXTOPLAND(0, 10, 0, -1, 0.5, 0, 1.5, 0, 4, 0.4, 4)
PRINT(landY = 0.0)
landY = BOXTOPLAND(0, 1.9, 0, 5, 0.5, 0, 1.5, 0, 4, 0.4, 4)
PRINT(landY = 0.0)
landY = BOXTOPLAND(10, 2, 0, -3, 0.5, 0, 1.5, 0, 4, 0.4, 4)
PRINT(landY = 0.0)
PRINT("BOXTOPLAND float test OK")
