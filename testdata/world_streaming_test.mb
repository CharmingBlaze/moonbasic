; World streaming smoke test — CGO + Raylib



Window.Open(960, 540, "World Streaming Test")

Window.SetFPS(60)



t = Terrain.Make(256, 256)

Terrain.FillPerlin(t, 0.03, 40)

Chunk.SetRange(t, 120, 200)

World.SetCenter(128, 128)

World.StreamEnable(TRUE)

World.Preload(t, 3)



cam = Camera.Make()

Camera.SetPos(cam, 128, 120, 200)

Camera.SetTarget(cam, 128, 0, 128)



WHILE NOT (Input.KeyDown(KEY_ESCAPE) OR Window.ShouldClose())

    dt# = Time.Delta()

    World.SetCenter(128 + SIN(Time.Get()) * 30, 128 + COS(Time.Get()) * 30)

    World.Update(dt#)

    Render.Clear(40, 50, 70)

    cam.Begin()

    Terrain.Draw(t)

    cam.End()

    Draw.Text(World.Status(), 8, 8, 14, 255, 255, 200, 255)

    Render.Frame()

WEND



Camera.Free(cam)

Terrain.Free(t)

Window.Close()

PRINT("World streaming test OK")

