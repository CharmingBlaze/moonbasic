PRINT(FORMAT$(MOVEX(0.0, 1.0, 0.0), "%.3f"))
PRINT(FORMAT$(MOVEZ(0.0, 1.0, 0.0), "%.3f"))
PRINT(FORMAT$(MOVEX(0.0, 0.0, 1.0), "%.3f"))
PRINT(FORMAT$(MOVEZ(0.0, 0.0, 1.0), "%.3f"))
PRINT(FORMAT$(MOVEX(1.5708, 1.0, 0.0), "%.3f"))
PRINT(FORMAT$(MOVEZ(1.5708, 1.0, 0.0), "%.3f"))
PRINT("MOVEXZ test OK")
