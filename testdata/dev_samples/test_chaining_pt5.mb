; Phase 5 API Standardization Test
; File, Array, Audio chaining and property symmetry

PRINT("--- Array Chaining ---")
a = Array.Create(5)
a = a.Fill(10).Push(20).Unshift(5).Sort().Reverse()
PRINT("Array size via property getter: ", a.GetSize())
PRINT("Array contents: ")
FOR i = 0 TO a.GetLen() - 1
    PRINT("  [", i, "] = ", a[i])
NEXT

PRINT("")
PRINT("--- File Chaining ---")
f = File.OpenWrite("test_pt5.bin")
f = f.Write("Hello").Write(" ").Write("MoonBASIC")
f.Close()

f = File.OpenRead("test_pt5.bin")
PRINT("File size: ", f.GetSize())
f = f.Seek(6)
PRINT("File Pos: ", f.GetPos())
line = f.ReadLine()
PRINT("Read from pos 6: '", line, "'")
f.Close()

PRINT("")
PRINT("--- Audio Chaining (Compilation Check) ---")
; Standard Audio/Sound/Music handles returning themselves for chaining
; We mock this by checking if the handle call returns the handle
s = Audio.LoadSound("test.wav") ; Might fail at runtime but check dispatch
IF s > 0 THEN
    s = s.Volume(0.5).Pitch(1.2).Pan(0.0).Play()
    PRINT("Audio chaining dispatch okay")
ENDIF

PRINT("")
PRINT("Verification Success!")
