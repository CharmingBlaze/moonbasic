ASSERT((YEAR() >= 1970) AND (YEAR() <= 3000), "YEAR range")
ASSERT((MONTH() >= 1) AND (MONTH() <= 12), "MONTH range")
ASSERT((DAY() >= 1) AND (DAY() <= 31), "DAY range")
ASSERT((HOUR() >= 0) AND (HOUR() <= 23), "HOUR range")
ASSERT((MINUTE() >= 0) AND (MINUTE() <= 59), "MINUTE range")
ASSERT((SECOND() >= 0) AND (SECOND() <= 59), "SECOND range")
ASSERT((MILLISECOND() >= 0) AND (MILLISECOND() <= 999), "MILLISECOND range")
ASSERT(TIMESTAMP() > 1000000000, "TIMESTAMP")
ASSERT(LEN(DATE$()) = 10, "DATE$")
ASSERT(LEN(TIME$()) = 8, "TIME$")
ASSERT(LEN(DATETIME$()) = 19, "DATETIME$")
ASSERT(ARGC() >= 1, "ARGC")
ASSERT(LEN(COMMAND$(0)) > 0, "COMMAND$(0)")
ASSERT(LEN(COMMAND$()) > 0, "COMMAND$() full line")
