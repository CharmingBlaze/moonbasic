PRINT(INT(LEN("hello")))
PRINT(LEFT("hello", 3))
PRINT(RIGHT("hello", 3))
PRINT(MID("hello", 1, 3))
PRINT(UPPER("hello"))
PRINT(LOWER("Hello"))
PRINT(TRIM("  hi  "))
PRINT(CONTAINS("foobar", "bar"))
PRINT(REPLACE("a-b-c", "-", "/"))
PRINT(INSTR("foobar", "bar"))
PRINT(STR(42))
PRINT(INT("99"))
PRINT(FLOAT("3.5"))
PRINT(CHR(65))
PRINT(ASC("A"))
PRINT(BIN(5))
PRINT(HEX(255))
