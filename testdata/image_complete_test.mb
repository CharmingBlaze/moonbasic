PRINT("=== Image Tests ===")

; Creation: (w,h) = transparent black; (w,h,r,g,b,a) = solid fill
img = IMAGE.CREATE(64, 64)
ASSERT(IMAGE.WIDTH(img) = 64, "CREATE 2-arg width")
ASSERT(IMAGE.HEIGHT(img) = 64, "CREATE 2-arg height")
ASSERT(IMAGE.GETCOLORA(img, 0, 0) = 0, "CREATE 2-arg transparent A")

IMAGE.CLEAR(img, 100, 150, 200, 255)
ASSERT(IMAGE.GETCOLORR(img, 0, 0) = 100, "CLEAR R")
ASSERT(IMAGE.GETCOLORG(img, 0, 0) = 150, "CLEAR G")
ASSERT(IMAGE.GETCOLORB(img, 0, 0) = 200, "CLEAR B")
ASSERT(IMAGE.GETCOLORA(img, 0, 0) = 255, "CLEAR A")

IMAGE.DRAWPIXEL(img, 32, 32, 255, 0, 0, 255)
ASSERT(IMAGE.GETCOLORR(img, 32, 32) = 255, "pixel R")
ASSERT(IMAGE.GETCOLORG(img, 32, 32) = 0, "pixel G")
ASSERT(IMAGE.GETCOLORB(img, 32, 32) = 0, "pixel B")

IMAGE.COLORBRIGHTNESS(img, 30)
IMAGE.COLORCONTRAST(img, 10)

IMAGE.FLIPH(img)
IMAGE.FLIPV(img)
IMAGE.ROTATE(img, 90)

ASSERT(IMAGE.WIDTH(img) = 64, "WIDTH after rotate")
ASSERT(IMAGE.HEIGHT(img) = 64, "HEIGHT after rotate")

IMAGE.DRAWRECT(img, 5, 5, 20, 20, 255, 200, 50, 255)
IMAGE.DRAWCIRCLE(img, 45, 45, 10, 255, 50, 50, 255)
IMAGE.DRAWLINE(img, 0, 0, 63, 63, 200, 200, 200, 255)
IMAGE.DRAWTEXT(img, 2, 2, "Hi", 8, 255, 255, 255, 255)

ok = IMAGE.EXPORT(img, "testdata/image_test_out.png")
ASSERT(ok, "EXPORT png")
ASSERT(FILEEXISTS("testdata/image_test_out.png"), "FILEEXISTS out png")
IMAGE.FREE(img)

; Copy alias + 6-arg solid
src = IMAGE.CREATE(8, 8, 10, 20, 30, 255)
dup = IMAGE.COPY(src)
ASSERT(IMAGE.WIDTH(dup) = 8, "COPY width")
IMAGE.FREE(dup)
IMAGE.FREE(src)

img2 = IMAGE.CREATEBLANK(4, 4, 0, 0, 0, 0)
ASSERT(IMAGE.WIDTH(img2) = 4, "CREATEBLANK width")
IMAGE.FREE(img2)

gen = IMAGE.CREATE(32, 32, 255, 128, 64, 255)
ok2 = IMAGE.EXPORT(gen, "testdata/image_test.jpg")
ASSERT(ok2, "EXPORT jpg")
IMAGE.FREE(gen)

PRINT("Image tests OK")
