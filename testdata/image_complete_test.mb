img = IMAGE.MAKE(8, 8, 10, 20, 30, 255)
ASSERT(IMAGE.WIDTH(img) = 8, "MAKE width")
ASSERT(IMAGE.HEIGHT(img) = 8, "MAKE height")

IMAGE.DRAWPIXEL(img, 0, 0, 1, 2, 3, 255)
ASSERT(IMAGE.GETCOLORR(img, 0, 0) = 1, "GETCOLORR")
ASSERT(IMAGE.GETCOLORG(img, 0, 0) = 2, "GETCOLORG")
ASSERT(IMAGE.GETCOLORB(img, 0, 0) = 3, "GETCOLORB")
ASSERT(IMAGE.GETCOLORA(img, 0, 0) = 255, "GETCOLORA")

img2 = IMAGE.MAKEBLANK(4, 4, 0, 0, 0, 0)
ASSERT(IMAGE.WIDTH(img2) = 4, "MAKEBLANK width")
IMAGE.FREE(img2)

IMAGE.FREE(img)

PRINT("image_complete_test ok")
