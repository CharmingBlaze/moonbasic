; NOISE.* unit checks (no window) — uses real registry APIs only
; Use ng (not "noise") so the NOISE namespace is not shadowed by a variable name.

ng = Noise.Create()
Noise.SetType(ng, "perlin")
Noise.SetSeed(ng, 42)
Noise.SetFrequency(ng, 0.01)

h = Noise.Get(ng, 0, 0)
PRINT(h >= -1.0 AND h <= 1.0)

PRINT(Noise.Get(ng, 100, 200) = Noise.Get(ng, 100, 200))

PRINT(Noise.Get(ng, 0, 0) <> Noise.Get(ng, 1000, 1000))

h2 = Noise.GetNorm(ng, 50, 50)
PRINT(h2 >= 0.0 AND h2 <= 1.0)

Noise.Free(ng)

fbm = Noise.MakeFractal(1337, 0.005, 5, "fbm")
PRINT(Noise.Get(fbm, 0, 0) >= -1.0)
Noise.Free(fbm)

cell = Noise.MakeCellular(999, 0.02, "distance")
PRINT(Noise.Get(cell, 0, 0) >= -1.0)
Noise.Free(cell)

PRINT("Noise unit tests OK")
