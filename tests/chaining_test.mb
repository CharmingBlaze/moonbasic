; MoonBASIC Method Chaining & Handle Method Registry Test

; 1. Test Camera Chaining
cam = CAMERA.CREATE().pos(0, 10, 20).look(0, 0, 0).fov(60)

PRINT("Camera Handle: ", cam)
p = cam.pos()
PRINT("Camera Pos: ", p.x, p.y, p.z)
PRINT("Camera FOV: ", cam.fov()) ; Note: .fov() dispatch might need verify

