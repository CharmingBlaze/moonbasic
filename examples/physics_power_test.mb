; Physics Power Verification
; This script tests the new VEHICLE, AERO, and BODY3D commands.

CLS
PRINT "Starting Physics Verification..."

; 1. Body and Aero Setup
shape = SHAPE.CREATEBOX(1, 1, 1)
body = BODY3D.MAKE("DYNAMIC")
BODY3D.ADDBOX(body, 1, 1, 1)
bh = BODY3D.COMMIT(body, 0, 10, 0)

AERO.SETLIFT(bh, 0.5)
AERO.SETTHRUST(bh, 10.0)
PRINT "Aero configured."

; 2. Vehicle Setup
hero = ENTITY.CREATE("HERO")
vid = VEHICLE.CREATE(hero, 4)
VEHICLE.SETWHEEL(vid, 0, -1, -0.5, 1, 0.4)
VEHICLE.SETWHEEL(vid, 1, 1, -0.5, 1, 0.4)
VEHICLE.SETWHEEL(vid, 2, -1, -0.5, -1, 0.4)
VEHICLE.SETWHEEL(vid, 3, 1, -0.5, -1, 0.4)
VEHICLE.SETTUNING(vid, 20.0, 1.0, 50.0, 2.0)
PRINT "Vehicle configured: ", vid

; 3. Handle Method Check
hero.SETTHROTTLE(1.0)
hero.SETSTEER(0.5)
bh.SETVELOCITY(0, 5, 0)

; 4. Interrogation
mass = bh.GETMASS()
PRINT "Body Mass: ", mass

vel = bh.GETVELOCITY()
PRINT "Body Velocity Array Handle: ", vel

PRINT "Verification Complete (Syntax Check)."
END
